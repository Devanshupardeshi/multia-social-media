{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": null,
  "buildCommand": "",
  "outputDirectory": "public",
  "functions": {
    "api/index.js": { "maxDuration": 60, "includeFiles": "public/**" }
  },
  "rewrites": [
    { "source": "/(.*)", "destination": "/api/index" }
  ]
}
