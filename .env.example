# Copy this file to .env and fill in your Instagram Graph API details.
#
# The access token should belong to the Facebook/Instagram app user with access
# to the Instagram professional account you want to monitor.
INSTAGRAM_ACCESS_TOKEN=
INSTAGRAM_USER_ID=

# Keep this configurable because Meta Graph API versions move over time.
GRAPH_API_VERSION=v23.0

# auto detects most tokens. Use instagram for tokens generated from the Instagram setup screen,
# or facebook for Facebook Login/System User tokens.
INSTAGRAM_API_MODE=auto

# Dashboard server settings.
PORT=4173
DASHBOARD_REFRESH_MS=60000
